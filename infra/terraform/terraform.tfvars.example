aws_region  = "ap-south-1"
environment = "prod"

budget_alert_emails = ["owner@example.com"]

# Required before first real login: the email address that should become the
# first owner/admin in the app after that Cognito user is invited.
initial_owner_admin_email = "owner@example.com"

# Optional: set when the Route 53 hosted zone already exists.
# route53_zone_id = "Z1234567890ABCDEFG"

# Optional: set to a globally unique Cognito hosted UI domain prefix.
# cognito_domain_prefix = "pailo-prod-auth"

# Optional: set after CI pushes immutable image tags to ECR.
# image_tag = "2026-05-02-001"

# Optional: RDS PostgreSQL defaults to 18 when available in ap-south-1.
# If AWS has not enabled 18 in the region yet, set the newest supported version.
# postgres_engine_version = "17"
