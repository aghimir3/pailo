{
  "name": "pailo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:frontend": "corepack pnpm --filter @pailo/frontend dev",
    "dev:backend": "uv run --project apps/backend uvicorn app.main:app --app-dir apps/backend --reload --host 0.0.0.0 --port 8000",
    "build:frontend": "corepack pnpm --filter @pailo/frontend build",
    "typecheck": "corepack pnpm --filter @pailo/frontend typecheck",
    "lint": "corepack pnpm --filter @pailo/frontend lint",
    "generate:api": "corepack pnpm --filter @pailo/api-client generate",
    "test:backend": "uv run --project apps/backend pytest"
  }
}
